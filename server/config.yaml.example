storage:
  # Where completed transcripts are written
  # Default: ~/.local/share/sotto (follows XDG convention)
  # Time-bucketed: output_dir/completed/YYYY/MM/uuid.txt and uuid.json
  output_dir: ~/.local/share/sotto

  # Where incoming audio uploads are stored temporarily
  # Default: output_dir/incoming
  # incoming_dir: ~/.local/share/sotto/incoming

pipelines:
  private:
    transcription: local         # Always Whisper
    llm_backend: ollama
    model: llama3.1:8b

  standard:
    transcription: local         # Always Whisper
    llm_backend: anthropic
    model: claude-sonnet-4-6

api_keys:
  anthropic: sk-...
  # openai: sk-...              # Optional alternative

ollama:
  # Ollama runs on the host, outside Docker.
  # "host.docker.internal" resolves to the Docker host.
  # If running sotto natively (not in Docker), use http://localhost:11434.
  endpoint: http://host.docker.internal:11434

whisper:
  model: large-v3
  device: cuda                   # or cpu

server:
  host: 0.0.0.0
  port: 8377

auth:
  # Bearer token(s) for authenticating iOS app uploads
  tokens:
    - "change-me-to-a-real-token"

# Where classified notes are dispatched to (Obsidian vault)
destinations:
  obsidian_vault: ~/.local/share/sotto/vault

# Pattern triggers for fast-path classification (skip LLM)
patterns:
  - trigger: "note to self"
    intent: note_to_self
  - trigger: "meeting with"
    intent: meeting_debrief
  - trigger: "plan for"
    intent: plan_request
  - trigger: "create a plan"
    intent: plan_request
  - trigger: "I want to work on"
    intent: plan_request
  - trigger: "investigate"
    intent: plan_request

# Projects that can be targeted by plan_request dictations.
# The classifier extracts project names from your dictation and matches
# them to these entries. If only one project is configured, it's used
# as the default.
projects:
  # Short form — just a path:
  # sotto: ~/sotto
  #
  # Full form with aliases:
  # sotto:
  #   path: ~/sotto
  #   aliases: ["soto", "voice app"]
