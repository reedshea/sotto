storage:
  # Where completed transcripts are written
  # Default: ~/.local/share/sotto (follows XDG convention)
  # Time-bucketed: output_dir/completed/YYYY/MM/uuid.txt and uuid.json
  output_dir: ~/.local/share/sotto

  # Where incoming audio uploads are stored temporarily
  # Default: output_dir/incoming
  # incoming_dir: ~/.local/share/sotto/incoming

pipelines:
  private:
    transcription: local         # Always Whisper
    llm_backend: ollama
    model: llama3.1:8b

  standard:
    transcription: local         # Always Whisper
    llm_backend: anthropic
    model: claude-sonnet-4-6

api_keys:
  anthropic: sk-...
  # openai: sk-...              # Optional alternative

ollama:
  # Ollama runs on the host, outside Docker.
  # "host.docker.internal" resolves to the Docker host.
  # If running sotto natively (not in Docker), use http://localhost:11434.
  endpoint: http://host.docker.internal:11434

whisper:
  model: large-v3
  device: cuda                   # or cpu

server:
  host: 0.0.0.0
  port: 8377

auth:
  # Bearer token(s) for authenticating iOS app uploads
  tokens:
    - "change-me-to-a-real-token"

# Named output destinations — add as many as you need.
# Each key is a name, each value is a path.
destinations:
  obsidian_vault: ~/.local/share/sotto/vault
  # e-reader: G:\My Drive\Rakuten Kobo

# Pattern triggers for fast-path classification (skip LLM)
patterns:
  - trigger: "note to self"
    intent: note_to_self
  - trigger: "meeting with"
    intent: meeting_debrief
  - trigger: "plan for"
    intent: plan_request
  - trigger: "create a plan"
    intent: plan_request
  - trigger: "I want to work on"
    intent: plan_request
  - trigger: "investigate"
    intent: plan_request
  - trigger: "go implement"
    intent: code_request
  - trigger: "go build"
    intent: code_request
  - trigger: "go fix"
    intent: code_request
  - trigger: "implement"
    intent: code_request
  - trigger: "fix the"
    intent: code_request

# Projects that can be targeted by plan_request dictations.
# The classifier extracts project names from your dictation and matches
# them to these entries. If only one project is configured, it's used
# as the default.
projects:
  # Short form — just a path:
  # sotto: ~/sotto
  #
  # Full form with aliases:
  # sotto:
  #   path: ~/sotto
  #   aliases: ["soto", "voice app"]

# Orchestrator — async Claude Code CLI session manager.
# This is the glue layer: voice memo -> Claude Code session -> report.
# Requires `claude` CLI on PATH.
orchestrator:
  # How many Claude CLI instances can run at once
  max_concurrent: 4
  # Per-task timeout in seconds
  timeout_seconds: 600
  # Where to store session state (default: output_dir/orchestrator.db)
  # session_store_path: ~/.local/share/sotto/orchestrator.db
  # Where to write completed reports (default: vault_root/reports)
  # report_dir: ~/.local/share/sotto/vault/reports
  # Allow Claude CLI to edit files and run shell commands.
  # Required for code_request (PR creation). Plan requests benefit from
  # shell access for codebase exploration. Default: true
  # allow_edits: true

# ─── Setup Checklist ───────────────────────────────────────────
# Before voice-to-action (plan/code requests) will work:
#
# 1. Configure at least one project above with a valid local path
#    Example:
#      projects:
#        sotto:
#          path: ~/sotto
#          aliases: ["soto", "voice app"]
#
# 2. Install and authenticate the Claude CLI:
#    npm install -g @anthropic-ai/claude-code
#    claude  # (follow OAuth prompts)
#
# 3. (Optional) Install and authenticate the GitHub CLI for PR creation:
#    https://cli.github.com/
#    gh auth login
#    Without gh, code_request will push a branch but skip PR creation.
#
# 4. Ensure the Sotto service runs as YOUR user (not SYSTEM):
#    sotto install-service --run-as YOUR_USERNAME
#    This is required so claude and gh can find your auth tokens.
#
# 5. Verify:
#    claude --version    # should print version
#    gh auth status      # should show logged in (if installed)
#    sotto status        # should show service running
