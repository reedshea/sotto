storage:
  # Where completed transcripts are written
  # Default: ~/.local/share/sotto (follows XDG convention)
  # Time-bucketed: output_dir/completed/YYYY/MM/uuid.txt and uuid.json
  output_dir: ~/.local/share/sotto

  # Where incoming audio uploads are stored temporarily
  # Default: output_dir/incoming
  # incoming_dir: ~/.local/share/sotto/incoming

pipelines:
  private:
    transcription: local         # Always Whisper
    llm_backend: ollama
    model: llama3.1:34b

  standard:
    transcription: local         # Always Whisper
    llm_backend: anthropic
    model: claude-sonnet-4-6

api_keys:
  anthropic: sk-...
  # openai: sk-...              # Optional alternative

ollama:
  endpoint: http://localhost:11434

whisper:
  model: large-v3
  device: cuda                   # or cpu

server:
  host: 0.0.0.0
  port: 8377

auth:
  # Bearer token(s) for authenticating iOS app uploads
  tokens:
    - "change-me-to-a-real-token"
